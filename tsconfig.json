{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "#app": ["./node_modules/nuxt/dist/app/index.d.ts"]
    }
  },
  "include": ["src/**/*", "test/**/*"]
}
